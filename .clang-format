# Formatting config for Graphene (the clang-format analog of a Spotless config).
# Apply:  clang-format -i <files>     (or: cmake --build build --target format)
# Check:  clang-format --dry-run --Werror <files>  (target: format-check)
---
Language: Cpp
BasedOnStyle: Google
IndentWidth: 4
ColumnLimit: 100
AccessModifierOffset: -4
PointerAlignment: Left
DerivePointerAlignment: false
